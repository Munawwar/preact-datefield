{
  "name": "preact-datefield",
  "version": "0.1.0",
  "description": "Preact date input with natural language parsing and autocomplete",
  "main": "dist/cjs/PreactDatefield.js",
  "module": "dist/esm/PreactDatefield.js",
  "exports": {
    ".": {
      "types": "./dist/esm/PreactDatefield.d.ts",
      "require": "./dist/cjs/PreactDatefield.js",
      "default": "./dist/esm/PreactDatefield.js"
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently -i -c \"auto\" \"npm:watch\" \"npm:example\"",
    "lint": "npx @biomejs/biome check --write",
    "tsc": "tsc",
    "test:parser": "node --test test/dateParser.test.mjs",
    "example": "browser-sync start --port 3050 --server --files 'example' --files 'dist' --startPath '/example/example.html'",
    "watch": "esbuild ./lib/PreactDatefield.jsx --outdir=dist/esm --format=esm --bundle --jsx-factory=h --jsx-fragment=Fragment --jsx=automatic --sourcemap --external:preact --external:@popperjs/core --watch",
    "build": "bash build.sh",
    "prepare": "husky",
    "pretest": "npm run build"
  },
  "keywords": [
    "preact",
    "date",
    "datepicker",
    "datefield",
    "date-input",
    "natural-language",
    "autocomplete"
  ],
  "author": "Munawwar",
  "license": "MIT",
  "repository": "https://github.com/Munawwar/preact-datefield",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@popperjs/core": "^2.0.0",
    "browser-sync": "^3.0.2",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "husky": "^9.1.7",
    "preact": "^10.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@popperjs/core": "^2.0.0",
    "preact": "^10.0.0"
  },
  "engines": {
    "node": ">= 10.0.0"
  }
}
